{
  "extends": ["config:best-practices"],
  "lockFileMaintenance": {
    "enabled": true,
    "labels": ["patch", "renovate-deps"]
  },
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "groupName": "dependencies",
      "matchUpdateTypes": ["major"],
      "matchDepTypes": ["dependencies"],
      "labels": ["minor", "renovate-deps"]
    },
    {
      "groupName": "dependencies",
      "matchUpdateTypes": ["patch", "minor"],
      "matchDepTypes": ["dependencies"],
      "labels": ["patch", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["@vercel/ncc"],
      "labels": ["patch", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "labels": ["no release", "renovate-deps"],
      "automerge": true,
      "matchPackageNames": ["!@vercel/ncc", "!typescript"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["patch"],
      "labels": ["no release", "renovate-deps"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["minor"],
      "labels": ["no release", "renovate-deps"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["major"],
      "labels": ["patch", "renovate-deps"]
    },
    {
      "matchUpdateTypes": ["pin", "pinDigest"],
      "minimumReleaseAge": null,
      "automerge": true
    },
    {
      "description": "Pin GitHub Actions to commit SHAs only for third-party repos (not Smartly-owned)",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["/^smartlyio\\//"],
      "pinDigests": false
    }
  ],
  "github-actions": {
    "enabled": true,
    "labels": ["no release", "renovate-deps"],
    "automerge": true
  },
  "minimumReleaseAge": "30 days"
}
